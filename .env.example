SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
APP_PUBLIC_BASE_URL=https://iq-arena.telonyx.app
APP_WEBAPP_URL=https://iq-arena.telonyx.app/app

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/iqarena
SPRING_DATASOURCE_USERNAME=iqarena
SPRING_DATASOURCE_PASSWORD=iqarena
SPRING_DATA_REDIS_URL=redis://localhost:6379
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=iqarena
SPRING_RABBITMQ_PASSWORD=iqarena
APP_OUTBOX_RABBIT_ENABLED=true
APP_OUTBOX_RABBIT_EXCHANGE=iq-arena.domain-events
APP_OUTBOX_RABBIT_ROUTING_KEY_PREFIX=iq-arena
APP_OUTBOX_RABBIT_CONFIRM_TIMEOUT_MS=5000
APP_MATCHMAKING_BOT_WAIT_SECONDS=4
APP_MATCHMAKING_REDIS_QUEUE_KEY=iq-arena:matchmaking:queue
APP_MATCHMAKING_REDIS_CATEGORY_KEY=iq-arena:matchmaking:category
APP_MATCHMAKING_REDIS_LOCK_KEY=iq-arena:matchmaking:lock
APP_MATCHMAKING_REDIS_LOCK_TTL_MS=3000
APP_MATCHMAKING_REDIS_STALE_AFTER_SECONDS=60
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_MAX_REQUESTS=60
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_RATE_LIMIT_KEY_PREFIX=iq-arena:rate-limit
MANAGEMENT_TRACING_ENABLED=true
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.1
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://localhost:4318/v1/traces

APP_JWT_SECRET=change-me-change-me-change-me-change-me-change-me

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=iq_arena_bot
TELEGRAM_WEBAPP_URL=https://iq-arena.telonyx.app/app
